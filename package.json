{
  "name": "hop-ledger",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "hop-verifier": "./dist/src/cli/verifier.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify:envelope": "node dist/src/cli/verifier.js verify-envelope",
    "verify:run": "node dist/src/cli/verifier.js verify-run",
    "preconformance": "npm run build",
    "conformance": "node scripts/conformance-check.mjs",
    "pilot:openclaw": "npm run build && node scripts/openclaw-pilot-run.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "typescript": "^5.9.2"
  }
}

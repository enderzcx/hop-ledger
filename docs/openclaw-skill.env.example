# OpenClaw skill-mode pilot env template
# Copy to your terminal session or a local .env file.

# Required
HOP_PILOT_MODE=skill
HOP_PILOT_PAYER=0xYourAaWalletAddress

# Optional routing
HOP_PILOT_SKILL_ENDPOINT=http://127.0.0.1:3001/api/skill/openclaw/invoke
HOP_PILOT_SOURCE_AGENT_ID=1
HOP_PILOT_TARGET_AGENT_ID=2

# Optional autopay controls
HOP_PILOT_AUTO_PAY=1
HOP_PILOT_PAY_ENDPOINT=http://127.0.0.1:3001/api/session/pay
HOP_PILOT_SESSION_ID=
HOP_PILOT_PAY_ACTION=reactive-stop-orders

# Optional task payload
HOP_PILOT_CAPABILITY=reactive-stop-orders
HOP_PILOT_SYMBOL=BTC
HOP_PILOT_TP=120000
HOP_PILOT_SL=70000
HOP_PILOT_QTY=0.001
